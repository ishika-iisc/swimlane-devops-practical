# Copy this file to production.tfvars and replace the placeholder values before
# applying against EKS.

namespace             = "swimlane"
node_env              = "production"
app_image             = "ghcr.io/<user>/swimlane-devops-practical:1.0.0"
app_image_pull_policy = "IfNotPresent"

mongo_root_password = "<replace-with-a-strong-root-password>"
mongo_app_password  = "<replace-with-a-strong-app-password>"

enable_network_policy = true
enable_ingress        = true
ingress_host          = "swimlane.example.com"
ingress_class_name    = "nginx"
ingress_tls_secret_name = "swimlane-tls"
