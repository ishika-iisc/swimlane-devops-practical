apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: swimlane

resources:
  - ../../base
  - ingress.yaml

images:
  - name: swimlane-devops-practical
    newName: 978355780214.dkr.ecr.us-east-1.amazonaws.com/swimlane-practical-prod
    newTag: latest

patches:
  - path: patch-app-production.yaml
